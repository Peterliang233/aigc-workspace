# MySQL
MYSQL_ROOT_PASSWORD=aigcpass
MYSQL_DATABASE=aigc
MYSQL_PORT=3307

# For local `go run` (host) + `make mysql-up` (mysql in docker), use this DSN.
# `make dev-backend` will auto-prefer MYSQL_DSN_LOCAL over MYSQL_DSN.
MYSQL_DSN_LOCAL=root:aigcpass@tcp(127.0.0.1:3307)/aigc?parseTime=true&charset=utf8mb4&collation=utf8mb4_unicode_ci

# Backend (required)
PORT=8080
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:5173
MYSQL_DSN=root:aigcpass@tcp(mysql:3306)/aigc?parseTime=true&charset=utf8mb4&collation=utf8mb4_unicode_ci

# Models config (repo-managed JSON)
# Backend loads this file at startup. Default: models.json (in backend/ working dir or /app in container).
MODELS_CONFIG_PATH=models.json

# Backward-compatible shared settings (single-provider mode).
# Prefer provider-specific vars when configuring multiple providers at once.
AIGC_BASE_URL=
AIGC_API_KEY=

OPENAI_COMPAT_BASE_URL=
OPENAI_COMPAT_API_KEY=

SILICONFLOW_BASE_URL=https://api.siliconflow.cn
SILICONFLOW_API_KEY=

WUYIN_BASE_URL=https://api.wuyinkeji.com
WUYIN_API_KEY=

# Video (optional)
# Async video endpoints for "openai_compatible" generic provider (optional).
# SiliconFlow video is enabled automatically when SILICONFLOW_API_KEY is set.
AIGC_VIDEO_START_ENDPOINT=
AIGC_VIDEO_STATUS_ENDPOINT=

# MinIO (asset storage for history)
# Backend reads MINIO_ACCESS_KEY/MINIO_SECRET_KEY, but also falls back to MINIO_ROOT_USER/MINIO_ROOT_PASSWORD.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=aigc-assets

# In docker compose, use service DNS. When running backend on host, prefer MINIO_ENDPOINT_LOCAL.
MINIO_ENDPOINT=minio:9000
MINIO_ENDPOINT_LOCAL=127.0.0.1:9000
MINIO_USE_SSL=false

# Optional port mappings for docker compose
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
LOG_FILE=

# Downstream request logging:
# - Prompt logging is redacted by default: sha256 + length + a short preview.
# - Set LOG_PROMPT_FULL=true only for local debugging (may contain sensitive info).
LOG_PROMPT_PREVIEW_CHARS=120
LOG_PROMPT_FULL=false

# Frontend dev (docker compose dev)
CHOKIDAR_USEPOLLING=true
