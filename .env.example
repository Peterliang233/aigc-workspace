# MySQL
MYSQL_ROOT_PASSWORD=aigcpass
MYSQL_DATABASE=aigc

# Backend (required)
PORT=8080
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:5173
MYSQL_DSN=root:aigcpass@tcp(mysql:3306)/aigc?parseTime=true&charset=utf8mb4&collation=utf8mb4_unicode_ci

# Image providers (env-managed)
AIGC_PROVIDER=mock

OPENAI_COMPAT_BASE_URL=
OPENAI_COMPAT_API_KEY=
OPENAI_COMPAT_IMAGE_MODEL=
OPENAI_COMPAT_IMAGE_MODELS=

SILICONFLOW_BASE_URL=https://api.siliconflow.cn
SILICONFLOW_API_KEY=
SILICONFLOW_IMAGE_MODEL=Kwai-Kolors/Kolors
SILICONFLOW_IMAGE_MODELS=Kwai-Kolors/Kolors

WUYIN_BASE_URL=https://api.wuyinkeji.com
WUYIN_API_KEY=
WUYIN_IMAGE_MODELS=image_nanoBanana2,image_nanoBanana_pro
WUYIN_IMAGE_ENDPOINTS=

# Video (optional)
AIGC_VIDEO_MODEL=
AIGC_VIDEO_START_ENDPOINT=
AIGC_VIDEO_STATUS_ENDPOINT=

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Frontend dev (docker compose dev)
CHOKIDAR_USEPOLLING=true
