FROM golang:1.23-alpine AS build

WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -o /out/media-worker ./cmd/media-worker

FROM alpine:3.20
RUN apk add --no-cache ca-certificates ffmpeg

WORKDIR /app
COPY --from=build /out/media-worker /app/media-worker

ENV MEDIA_WORKER_PORT=8090
EXPOSE 8090
ENTRYPOINT ["/app/media-worker"]
