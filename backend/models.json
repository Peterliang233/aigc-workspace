{
  "version": 2,
  "defaults": {
    "image_provider": "siliconflow",
    "video_provider": "siliconflow",
    "audio_provider": "bltcy"
  },
  "providers": [
    {
      "id": "mock",
      "label": "Mock(联调)",
      "image": { "default_model": "", "models": [] },
      "video": { "default_model": "", "models": [] }
    },
    {
      "id": "siliconflow",
      "label": "SiliconFlow",
      "image": {
        "default_model": "Qwen/Qwen-Image",
        "models": [
          {
            "id": "Qwen/Qwen-Image",
            "form": {
              "fields": [
                { "key": "prompt", "label": "Prompt", "type": "textarea", "required": true, "rows": 6 },
                {
                  "key": "size",
                  "label": "Size",
                  "type": "select",
                  "default": "1024x1024",
                  "options": [
                    { "label": "1024x1024", "value": "1024x1024" },
                    { "label": "768x1024", "value": "768x1024" },
                    { "label": "1024x768", "value": "1024x768" }
                  ]
                }
              ]
            }
          },
          { "id": "Kwai-Kolors/Kolors" }
        ]
      },
      "video": {
        "default_model": "Wan-AI/Wan2.2-T2V-A14B",
        "models": [
          {
            "id": "Wan-AI/Wan2.2-T2V-A14B",
            "label": "Wan 2.2 T2V",
            "form": {
              "fields": [
                { "key": "prompt", "label": "Prompt", "type": "textarea", "required": true, "rows": 6 },
                { "key": "negative_prompt", "label": "Negative Prompt", "type": "textarea", "rows": 3 },
                {
                  "key": "image_size",
                  "label": "Size",
                  "type": "select",
                  "default": "1280x720",
                  "options": [
                    { "label": "1280x720 (16:9)", "value": "1280x720" },
                    { "label": "720x1280 (9:16)", "value": "720x1280" },
                    { "label": "960x960 (1:1)", "value": "960x960" }
                  ]
                },
                { "key": "seed", "label": "Seed", "type": "number", "placeholder": "例如 42" }
              ]
            }
          },
          {
            "id": "Wan-AI/Wan2.2-I2V-A14B",
            "label": "Wan 2.2 I2V",
            "form": {
              "requires_image": true,
              "fields": [
                { "key": "prompt", "label": "Prompt", "type": "textarea", "required": true, "rows": 6 },
                { "key": "image", "label": "参考图片", "type": "image", "required": true },
                { "key": "negative_prompt", "label": "Negative Prompt", "type": "textarea", "rows": 3 },
                {
                  "key": "image_size",
                  "label": "Size",
                  "type": "select",
                  "default": "1280x720",
                  "options": [
                    { "label": "1280x720 (16:9)", "value": "1280x720" },
                    { "label": "720x1280 (9:16)", "value": "720x1280" },
                    { "label": "960x960 (1:1)", "value": "960x960" }
                  ]
                },
                { "key": "seed", "label": "Seed", "type": "number", "placeholder": "例如 42" }
              ]
            }
          }
        ]
      }
    },
    {
      "id": "wuyinkeji",
      "label": "无印科技(速创API)",
      "image": {
        "default_model": "image_nanoBanana_pro",
        "models": [
          {
            "id": "image_nanoBanana_pro",
            "form": {
              "fields": [
                { "key": "prompt", "label": "Prompt", "type": "textarea", "required": true, "rows": 6 },
                {
                  "key": "aspect_ratio",
                  "label": "Aspect Ratio",
                  "type": "select",
                  "default": "1:1",
                  "options": [
                    { "label": "1:1", "value": "1:1" },
                    { "label": "16:9", "value": "16:9" },
                    { "label": "9:16", "value": "9:16" },
                    { "label": "4:3", "value": "4:3" },
                    { "label": "3:4", "value": "3:4" }
                  ]
                },
                {
                  "key": "size",
                  "label": "Size",
                  "type": "select",
                  "default": "1024x1024",
                  "options": [
                    { "label": "1024x1024", "value": "1024x1024" },
                    { "label": "768x1024", "value": "768x1024" },
                    { "label": "1024x768", "value": "1024x768" }
                  ]
                }
              ]
            }
          }
        ]
      }
    },
    {
      "id": "openai_compatible",
      "label": "OpenAI Compatible",
      "image": {
        "default_model": "gpt-image-1",
        "models": [
          {
            "id": "gpt-image-1",
            "form": {
              "fields": [
                { "key": "prompt", "label": "Prompt", "type": "textarea", "required": true, "rows": 6 },
                { "key": "size", "label": "Size", "type": "select", "default": "1024x1024", "options": [
                  { "label": "1024x1024", "value": "1024x1024" },
                  { "label": "512x512", "value": "512x512" },
                  { "label": "256x256", "value": "256x256" }
                ] }
              ]
            }
          }
        ]
      },
      "video": {
        "default_model": "",
        "models": []
      }
    },
    {
      "id": "bltcy",
      "label": "BLTCY(柏拉图)",
      "image": {
        "default_model": "gpt-4o-image",
        "models": [
          {
            "id": "gpt-4o-image",
            "label": "GPT 4o Image",
            "form": {
              "fields": [
                { "key": "prompt", "label": "Prompt", "type": "textarea", "required": true, "rows": 6 },
                { "key": "image", "label": "参考图片", "type": "image" }
              ]
            }
          },
          {
            "id": "qwen-image-edit",
            "label": "Qwen Image Edit",
            "form": {
              "fields": [
                { "key": "prompt", "label": "Prompt", "type": "textarea", "required": true, "rows": 6 },
                { "key": "image", "label": "参考图片", "type": "image", "required": true }
              ]
            }
          },
          {
            "id": "qwen-image-edit-2509",
            "label": "Qwen Image Edit 2509",
            "form": {
              "fields": [
                { "key": "prompt", "label": "Prompt", "type": "textarea", "required": true, "rows": 6 },
                { "key": "image", "label": "参考图片", "type": "image", "required": true }
              ]
            }
          },
          { "id": "gemini-2.5-flash-image", "label": "Gemini 2.5 Flash Image" },
          { "id": "gemini-3-pro-image-preview", "label": "Gemini 3 Pro Image Preview" },
          { "id": "qwen-image", "label": "Qwen Image" },
          { "id": "nano-banana", "label": "Nano Banana" }
        ]
      },
      "video": {
        "default_model": "wan2.2-t2v-plus",
        "models": [
          {
            "id": "wan2.2-t2v-plus",
            "label": "Wan 2.2 T2V Plus",
            "form": {
              "fields": [
                { "key": "prompt", "label": "Prompt", "type": "textarea", "required": true, "rows": 6 },
                { "key": "negative_prompt", "label": "Negative Prompt", "type": "textarea", "rows": 3 },
                {
                  "key": "duration_seconds",
                  "label": "Duration (sec)",
                  "type": "select",
                  "default": 5,
                  "options": [
                    { "label": "5", "value": "5" },
                    { "label": "10", "value": "10" }
                  ]
                },
                {
                  "key": "aspect_ratio",
                  "label": "Aspect Ratio",
                  "type": "select",
                  "default": "16:9",
                  "options": [
                    { "label": "16:9", "value": "16:9" },
                    { "label": "9:16", "value": "9:16" },
                    { "label": "1:1", "value": "1:1" },
                    { "label": "4:3", "value": "4:3" },
                    { "label": "3:4", "value": "3:4" }
                  ]
                },
                { "key": "seed", "label": "Seed", "type": "number", "placeholder": "例如 42" }
              ]
            }
          },
          {
            "id": "wan2.2-i2v-plus",
            "label": "Wan 2.2 I2V Plus",
            "form": {
              "requires_image": true,
              "fields": [
                { "key": "prompt", "label": "Prompt", "type": "textarea", "required": true, "rows": 6 },
                { "key": "image", "label": "参考图片", "type": "image", "required": true },
                { "key": "negative_prompt", "label": "Negative Prompt", "type": "textarea", "rows": 3 },
                {
                  "key": "duration_seconds",
                  "label": "Duration (sec)",
                  "type": "select",
                  "default": 5,
                  "options": [
                    { "label": "5", "value": "5" },
                    { "label": "10", "value": "10" }
                  ]
                },
                {
                  "key": "aspect_ratio",
                  "label": "Aspect Ratio",
                  "type": "select",
                  "default": "16:9",
                  "options": [
                    { "label": "16:9", "value": "16:9" },
                    { "label": "9:16", "value": "9:16" },
                    { "label": "1:1", "value": "1:1" },
                    { "label": "4:3", "value": "4:3" },
                    { "label": "3:4", "value": "3:4" }
                  ]
                },
                { "key": "seed", "label": "Seed", "type": "number", "placeholder": "例如 42" }
              ]
            }
          },
          { "id": "sora-2", "label": "Sora 2" },
          { "id": "veo3.1-fast", "label": "veo3.1-fast" },
          { "id": "vidu-q1", "label": "Vidu Q1" }
        ]
      },
      "audio": {
        "default_model": "tts-1",
        "models": [
          {
            "id": "tts-1",
            "label": "TTS 1",
            "form": {
              "fields": [
                { "key": "input", "label": "文本内容", "type": "textarea", "required": true, "rows": 6 },
                {
                  "key": "voice",
                  "label": "音色",
                  "type": "select",
                  "required": true,
                  "default": "alloy",
                  "options": [
                    { "label": "alloy", "value": "alloy" },
                    { "label": "echo", "value": "echo" },
                    { "label": "fable", "value": "fable" },
                    { "label": "onyx", "value": "onyx" },
                    { "label": "nova", "value": "nova" },
                    { "label": "shimmer", "value": "shimmer" }
                  ]
                },
                {
                  "key": "response_format",
                  "label": "输出格式",
                  "type": "select",
                  "default": "mp3",
                  "options": [
                    { "label": "mp3", "value": "mp3" },
                    { "label": "opus", "value": "opus" },
                    { "label": "aac", "value": "aac" },
                    { "label": "flac", "value": "flac" }
                  ]
                },
                { "key": "speed", "label": "语速", "type": "number", "default": 1, "placeholder": "0.25 - 4.0" }
              ]
            }
          },
          { "id": "tts-1-hd", "label": "TTS 1 HD" }
        ]
      }
    }
  ]
}
