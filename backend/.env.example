# Provider selection: "mock" | "openai_compatible" | "siliconflow"
AIGC_PROVIDER=mock

# Backward-compatible shared settings (single-provider mode).
# If you want to configure multiple providers at once, prefer the provider-specific vars below.
AIGC_BASE_URL=
AIGC_API_KEY=
AIGC_IMAGE_MODEL=

# OpenAI-compatible (optional; overrides AIGC_* when set)
OPENAI_COMPAT_BASE_URL=https://api.openai.com
OPENAI_COMPAT_API_KEY=
OPENAI_COMPAT_IMAGE_MODEL=
OPENAI_COMPAT_IMAGE_MODELS=

# SiliconFlow (optional; overrides AIGC_* when set)
SILICONFLOW_BASE_URL=https://api.siliconflow.cn
SILICONFLOW_API_KEY=
# Required for SiliconFlow if request.model is empty
SILICONFLOW_IMAGE_MODEL=Kwai-Kolors/Kolors
SILICONFLOW_IMAGE_MODELS=Kwai-Kolors/Kolors

# 无印科技(速创API) - async image generation
WUYIN_BASE_URL=https://api.wuyinkeji.com
WUYIN_API_KEY=
# Models shown in UI and accepted by backend (recommended).
# These are the dynamic URL segments: POST /api/async/{model}?key=...
WUYIN_IMAGE_MODELS=image_nanoBanana2,image_nanoBanana_pro
# Legacy mapping: label:endpointPath, e.g. NanoBanana2:/api/async/image_nanoBanana2
WUYIN_IMAGE_ENDPOINTS=

# Video settings (generic async)
# If you want to wire a vendor, implement internal/providers/openai_compatible/video.go or set these
AIGC_VIDEO_MODEL=
AIGC_VIDEO_START_ENDPOINT=
AIGC_VIDEO_STATUS_ENDPOINT=

# Server
PORT=8080
ALLOWED_ORIGINS=http://localhost:5173

# Optional: store settings in MySQL instead of local file.
# If set, backend will use MySQL as the source of truth for provider/model config.
# Required: store settings in MySQL (only).
MYSQL_DSN=root:aigcpass@tcp(127.0.0.1:3306)/aigc?parseTime=true&charset=utf8mb4&collation=utf8mb4_unicode_ci

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
