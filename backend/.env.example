# Provider selection: "mock" or "openai_compatible"
AIGC_PROVIDER=mock

# Base URL for OpenAI-compatible APIs, e.g. https://api.openai.com
AIGC_BASE_URL=https://api.openai.com
AIGC_API_KEY=

# Image settings (OpenAI-compatible)
AIGC_IMAGE_MODEL=

# Video settings (generic async)
# If you want to wire a vendor, implement internal/providers/openai_compatible/video.go or set these
AIGC_VIDEO_MODEL=
AIGC_VIDEO_START_ENDPOINT=
AIGC_VIDEO_STATUS_ENDPOINT=

# Server
PORT=8080
ALLOWED_ORIGINS=http://localhost:5173

